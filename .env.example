# Notion API Configuration
# Get your integration token from: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Notion Database IDs
# Find these in your Notion database URL after the workspace name
NOTION_DATABASE_ID=your_blog_posts_database_id
NOTION_PROJECTS_DB=your_projects_database_id
NOTION_BOOKS_DB=your_books_database_id
NOTION_TOOLS_DB=your_tools_database_id

# Cache Configuration (optional)
# Time to live for cache in milliseconds (default: 5 minutes)
CACHE_TTL=300000

# ISR Revalidation Secret
# Used to protect the manual revalidation endpoint
REVALIDATE_SECRET=your_secret_key_here

# Environment
NODE_ENV=production

# Optional: Error Monitoring
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Future: Supabase Configuration (Phase 2)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Future: Algolia Configuration (Phase 3)
# NEXT_PUBLIC_ALGOLIA_APP_ID=your_algolia_app_id
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your_algolia_search_api_key
# ALGOLIA_ADMIN_API_KEY=your_algolia_admin_api_key