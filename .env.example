# Notion Configuration
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion Database IDs
NOTION_PROJECTS_DB=your_projects_database_id_here
NOTION_BOOKS_DB=your_books_database_id_here
NOTION_TOOLS_DB=your_tools_database_id_here

# ConvertKit Configuration (Public)
# Only need Form ID for secure subscription
NEXT_PUBLIC_CONVERTKIT_FORM_ID=your_form_id_here

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Giscus Comments (Optional)
NEXT_PUBLIC_GISCUS_REPO=your-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=your_repo_id
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your_category_id

# Cache Configuration (Optional)
CACHE_TTL=3600000  # 1 hour in milliseconds

# Site Configuration
NEXT_PUBLIC_BASE_URL=https://yourdomain.com