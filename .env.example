# ==================================================
# Notion API 配置（必需）
# ==================================================
# Notion 集成 Token（以 secret_ 开头）
# 获取方式：https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 主博客文章数据库 ID（32位字符串）
# 从数据库 URL 中提取：https://notion.so/xxxxx/[这部分就是ID]?v=xxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# Notion 其他数据库配置（可选）
# ==================================================
# 项目展示数据库
NOTION_PROJECTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 书籍管理数据库
NOTION_BOOKS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 工具推荐数据库  
NOTION_TOOLS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# 邮件订阅配置（可选）
# ==================================================
# ConvertKit 表单 ID（公开的，安全）
# 从 ConvertKit 表单的嵌入代码中获取
NEXT_PUBLIC_CONVERTKIT_FORM_ID=1234567

# ==================================================
# 网站分析配置（可选）
# ==================================================
# Google Analytics 测量 ID
# 格式：G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==================================================
# 评论系统配置（可选）
# ==================================================
# Giscus 配置（基于 GitHub Discussions）
# 详细配置：https://giscus.app/zh-CN
NEXT_PUBLIC_GISCUS_REPO=your-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwxxxxxxxxxx

# ==================================================
# 性能优化配置（可选）
# ==================================================
# 缓存过期时间（毫秒）
# 默认：3600000（1小时）
# 建议值：开发环境 300000（5分钟），生产环境 3600000（1小时）
CACHE_TTL=3600000

# ==================================================
# 站点基础配置
# ==================================================
# 网站的完整 URL（用于 SEO 和社交分享）
# 注意：不要以斜杠结尾
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ==================================================
# 开发环境配置（可选）
# ==================================================
# Node 环境（development/production）
# Vercel 会自动设置，本地开发不需要设置
# NODE_ENV=development

# ==================================================
# 说明
# ==================================================
# 1. 复制此文件为 .env.local 并填入实际值
# 2. 必需的配置：NOTION_TOKEN 和 NOTION_DATABASE_ID
# 3. 其他配置根据需要填写
# 4. 生产环境请在 Vercel 控制台设置环境变量
# 5. 不要将 .env.local 提交到版本控制系统