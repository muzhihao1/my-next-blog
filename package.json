{
  "name": "my-blog",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:api": "tsx tests/api-integration/run-tests.ts",
    "test:api:auth": "tsx tests/api-integration/auth.test.ts",
    "test:api:comments": "tsx tests/api-integration/comments.test.ts",
    "test:notion": "node scripts/test-notion-connection.js",
    "test:supabase": "node scripts/test-supabase-connection.js",
    "db:init": "echo '请在 Supabase SQL Editor 中执行 scripts/supabase-init.sql'",
    "analyze": "node scripts/analyze-bundle.js",
    "build:analyze": "ANALYZE=true npm run build",
    "sync:algolia": "tsx scripts/sync-algolia.ts",
    "build:with-search": "npm run sync:algolia && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
